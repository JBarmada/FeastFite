import { useCallback, useEffect, useState } from 'react';
import { MapContainer, TileLayer, GeoJSON, Marker, useMap } from 'react-leaflet';
import type { Layer, PathOptions, Map as LMap } from 'leaflet';
import L from 'leaflet';
import type { Feature } from 'geojson';
import type { Territory } from '@feastfite/shared';
import 'leaflet/dist/leaflet.css';

import { MAP_CONFIG, TILE_PROVIDER } from '../../config/mapConfig';
import { territoryApi, type BBox } from '../../api/territoryApi';
import { getPlayerColorByIndex, playerColors, territoryColors, colors } from '../../styles/colors';
import { TerritoryPanel } from './TerritoryPanel';
import { DEV_TERRITORIES } from '../../config/devTerritories';
import type { MonsterHat } from '../ui/Monster';

function hashToIndex(id: string): number {
  let h = 0;
  for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) >>> 0;
  return h % playerColors.length;
}

const HAT_CYCLE: MonsterHat[] = ['burger', 'donut', 'taco', 'cone', 'sushi', 'ramen'];
const HAT_EMOJI: Record<MonsterHat, string> = {
  burger: '🍔', donut: '🍩', taco: '🌮', cone: '🍦', sushi: '🍣', ramen: '🍜',
};

function hatForOwner(id: string): MonsterHat {
  return HAT_CYCLE[hashToIndex(id) % HAT_CYCLE.length];
}

// ── GeoJSON centroid ──────────────────────────────────────────────────────────

function geoJsonCentroid(geoJson: unknown): [number, number] | null {
  try {
    const f = geoJson as { geometry: { type: string; coordinates: number[][][] } };
    if (f.geometry.type !== 'Polygon') return null;
    const ring = f.geometry.coordinates[0];
    const lat = ring.reduce((s, c) => s + c[1], 0) / ring.length;
    const lng = ring.reduce((s, c) => s + c[0], 0) / ring.length;
    return [lat, lng];
  } catch { return null; }
}

// ── Monster DivIcon ───────────────────────────────────────────────────────────

function createMonsterIcon(color: string, hat: MonsterHat, isLocked: boolean) {
  const emoji = HAT_EMOJI[hat];
  const lockDot = isLocked
    ? `<div style="position:absolute;top:-4px;right:-4px;width:17px;height:17px;border-radius:50%;background:${colors.accent};border:2px solid white;display:flex;align-items:center;justify-content:center;font-size:8px;line-height:1">🔒</div>`
    : '';
  const html = `<div style="width:38px;height:38px;border-radius:50%;background:white;border:3px solid ${color};box-shadow:0 3px 8px rgba(45,16,64,0.35);display:flex;align-items:center;justify-content:center;font-size:19px;position:relative;cursor:pointer">${emoji}${lockDot}</div>`;
  return L.divIcon({ html, className: '', iconSize: [38, 38], iconAnchor: [19, 19] });
}

// ── Polygon style ─────────────────────────────────────────────────────────────

type TerritoryState = 'unclaimed' | 'voting' | 'locked' | 'claimed';

function deriveState(t: Territory): TerritoryState {
  const isLocked = !!t.lockedUntil && new Date(t.lockedUntil) > new Date();
  if (!t.ownerId && isLocked) return 'voting';
  if (!t.ownerId) return 'unclaimed';
  if (isLocked) return 'locked';
  return 'claimed';
}

function polygonStyle(territory: Territory, isSelected: boolean): PathOptions {
  const state = deriveState(territory);
  const baseWeight = isSelected ? 5 : 3;
  const dash = isSelected ? '5 4' : undefined;

  if (state === 'voting') {
    return { fillColor: territoryColors.voting.fillColor, fillOpacity: 1, color: territoryColors.voting.color, weight: baseWeight, dashArray: dash };
  }
  if (state === 'unclaimed') {
    return { fillColor: territoryColors.unclaimed.fillColor, fillOpacity: 1, color: territoryColors.unclaimed.color, weight: baseWeight, dashArray: dash };
  }

  const palette = getPlayerColorByIndex(hashToIndex(territory.ownerId!));
  return { fillColor: palette.fill, fillOpacity: 1, color: palette.solid, weight: baseWeight, dashArray: dash };
}

// ── BBoxLoader ────────────────────────────────────────────────────────────────

interface LoaderProps {
  onLoad: (territories: Territory[]) => void;
  refreshKey?: number;
}

function BBoxLoader({ onLoad, refreshKey }: LoaderProps) {
  const map = useMap();

  const load = useCallback(async () => {
    const b = map.getBounds();
    const bbox: BBox = [b.getWest(), b.getSouth(), b.getEast(), b.getNorth()];
    try {
      const data = await territoryApi.getByBbox(bbox);
      if (data.length > 0) {
        onLoad(data);
      } else {
        onLoad(DEV_TERRITORIES);
      }
    } catch {
      // territory-service not running — show seed territories for dev preview
      onLoad(DEV_TERRITORIES);
    }
  }, [map, onLoad]);

  useEffect(() => {
    load();
    map.on('moveend', load);
    return () => { map.off('moveend', load); };
  }, [map, load]);

  useEffect(() => {
    if (refreshKey !== undefined) void load();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [refreshKey]);

  return null;
}

function MapRefCapture({ onMap }: { onMap: (m: LMap) => void }) {
  const map = useMap();
  useEffect(() => { onMap(map); }, [map, onMap]);
  return null;
}

// ── Overlays (outside MapContainer) ──────────────────────────────────────────

function TopHud({ territoryCount }: { territoryCount: number }) {
  return (
    <div style={{
      position: 'absolute', top: 12, left: 12, zIndex: 1000,
      display: 'flex', alignItems: 'center', gap: 10,
      background: 'white', borderRadius: 16,
      padding: '6px 14px 6px 6px',
      border: `3px solid ${colors.primary}`,
      boxShadow: '0 4px 0 #7A1A99, 0 6px 16px rgba(160,32,200,0.2)',
      pointerEvents: 'none',
    }}>
      <div style={{
        width: 40, height: 40, borderRadius: 12,
        background: colors.primary, display: 'grid', placeItems: 'center',
        color: 'white', fontFamily: 'var(--font-display)', fontSize: 22,
      }}>F</div>
      <div>
        <div style={{ fontFamily: 'var(--font-display)', fontSize: 16, color: colors.textPrimary, lineHeight: 1 }}>
          FeastFite
        </div>
        <div style={{ fontFamily: 'var(--font-mono)', fontSize: 10, color: colors.textSecondary, marginTop: 2 }}>
          {territoryCount > 0 ? `${territoryCount} GRUBS NEARBY` : 'SWEETLAND'}
        </div>
      </div>
    </div>
  );
}

function MapLegend() {
  return (
    <div style={{
      position: 'absolute', bottom: 16, left: 16, zIndex: 1000,
      background: 'white', borderRadius: 14, padding: '10px 14px',
      border: `3px solid ${colors.border}`,
      boxShadow: '0 3px 0 #D0B4E0',
      display: 'grid', gridTemplateColumns: '1fr 1fr',
      gap: '4px 14px', pointerEvents: 'none',
    }}>
      <LegendRow color={colors.secondary} label="Claimed" />
      <LegendRow color={colors.warning} label="Voting now" striped />
      <LegendRow color={colors.accent} label="Locked 12h" />
      <LegendRow color="#C4A0D8" label="Up for grabs" />
    </div>
  );
}

function LegendRow({ color, label, striped }: { color: string; label: string; striped?: boolean }) {
  return (
    <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
      <div style={{
        width: 16, height: 16, borderRadius: 5,
        border: `2px solid ${color}`,
        background: striped
          ? `repeating-linear-gradient(45deg, ${color}44 0 4px, ${color}99 4px 8px)`
          : `${color}66`,
        flexShrink: 0,
      }} />
      <span style={{
        fontFamily: 'var(--font-sans)', fontSize: 12, fontWeight: 700,
        color: colors.textPrimary, whiteSpace: 'nowrap',
      }}>{label}</span>
    </div>
  );
}

function ZoomControls({ map }: { map: LMap | null }) {
  const btn: React.CSSProperties = {
    width: 44, height: 44, borderRadius: 12,
    border: `3px solid ${colors.primary}`,
    background: 'white', color: colors.primary,
    fontFamily: 'var(--font-display)', fontSize: 22,
    boxShadow: '0 3px 0 #7A1A99',
    cursor: 'pointer', display: 'grid', placeItems: 'center',
  };
  return (
    <div style={{
      position: 'absolute', bottom: 16, right: 16, zIndex: 1000,
      display: 'flex', flexDirection: 'column', gap: 6,
    }}>
      <button style={btn} onClick={() => map?.zoomIn()} aria-label="Zoom in">+</button>
      <button style={btn} onClick={() => map?.zoomOut()} aria-label="Zoom out">−</button>
      <button style={{ ...btn, fontSize: 18 }} onClick={() => map?.locate({ setView: true })} aria-label="My location">⌖</button>
    </div>
  );
}

// ── MapView ───────────────────────────────────────────────────────────────────

interface MapViewProps {
  onClaim: (territory: Territory) => void;
  refreshKey?: number;
}

export function MapView({ onClaim, refreshKey }: MapViewProps) {
  const [territories, setTerritories] = useState<Territory[]>([]);
  const [selected, setSelected] = useState<Territory | null>(null);
  const [mapInstance, setMapInstance] = useState<LMap | null>(null);

  return (
    <div className="ff-map-view">
      <MapContainer
        center={MAP_CONFIG.defaultCenter}
        zoom={MAP_CONFIG.defaultZoom}
        minZoom={MAP_CONFIG.minZoom}
        maxZoom={MAP_CONFIG.maxZoom}
        maxBounds={MAP_CONFIG.maxBounds}
        maxBoundsViscosity={0.9}
        className="ff-map-canvas"
        style={{ width: '100%', height: '100%' }}
        zoomControl={false}
      >
        <TileLayer
          url={TILE_PROVIDER.url}
          attribution={TILE_PROVIDER.attribution}
          subdomains={TILE_PROVIDER.subdomains}
          maxNativeZoom={19}
          maxZoom={21}
        />

        <BBoxLoader onLoad={setTerritories} refreshKey={refreshKey} />
        <MapRefCapture onMap={setMapInstance} />

        {territories.map((territory) => (
          <GeoJSON
            key={`${territory.id}-${String(territory.updatedAt)}-${selected?.id === territory.id}`}
            data={territory.geoJson as Feature}
            style={() => polygonStyle(territory, selected?.id === territory.id)}
            onEachFeature={(_feature: Feature, layer: Layer) => {
              layer.on('click', () => {
                setSelected(territory);
                if ('bringToFront' in layer) {
                  (layer as { bringToFront: () => void }).bringToFront();
                }
              });
            }}
          />
        ))}

        {/* Monster flags at centroids of owned territories */}
        {territories.filter((t) => t.ownerId).map((territory) => {
          const centroid = geoJsonCentroid(territory.geoJson);
          if (!centroid) return null;
          const palette = getPlayerColorByIndex(hashToIndex(territory.ownerId!));
          const hat = hatForOwner(territory.ownerId!);
          const isLocked = !!territory.lockedUntil && new Date(territory.lockedUntil) > new Date();
          return (
            <Marker
              key={`flag-${territory.id}`}
              position={centroid}
              icon={createMonsterIcon(palette.solid, hat, isLocked)}
              eventHandlers={{ click: () => setSelected(territory) }}
            />
          );
        })}
      </MapContainer>

      <TopHud territoryCount={territories.length} />
      <MapLegend />
      <ZoomControls map={mapInstance} />

      <TerritoryPanel
        territory={selected}
        onClose={() => setSelected(null)}
        onClaim={onClaim}
        ownerName={selected?.ownerName ?? undefined}
      />
    </div>
  );
}
