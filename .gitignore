# Dependencies
node_modules/
.npm/

# Build output
dist/
build/

# Environment files (per-service .env, never commit real secrets)
services/**/.env
frontend/.env
.env
!.env.example

# TypeScript incremental build info
*.tsbuildinfo

# Editor
.vscode/
.idea/
*.sw[po]

# Claude Code local settings (per-developer, not shared)
.claude/

# OS
.DS_Store
Thumbs.db

# Docker local volumes
.docker-volumes/

# Logs
*.log
npm-debug.log*
session-export-*
*.zip

# k8s secrets with real values (use secrets.template.yml / secrets.env.example instead)
k8s/secrets.yml
k8s/secrets.env
