# ─────────────────────────────────────────────────────────────────────────────
# k8s/secrets.env.example — SAFE TO COMMIT (no real values)
#
# Setup:
#   cp k8s/secrets.env.example k8s/secrets.env   (Mac/Linux)
#   copy k8s\secrets.env.example k8s\secrets.env  (Windows)
#
# Then fill in real passwords and run:
#   powershell -File k8s/create-secrets.ps1
#
# Rules for passwords:
#   - 16+ characters
#   - Mix of letters and numbers is fine
#   - AVOID: @ $ % # ! (break the amqp:// URL interpolation)
#   - Example safe password: Feastfite2024Rocks
# ─────────────────────────────────────────────────────────────────────────────

PG_PASSWORD=CHANGE_ME
RMQ_PASSWORD=CHANGE_ME
MINIO_PASSWORD=CHANGE_ME
